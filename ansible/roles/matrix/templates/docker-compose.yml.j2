services:
  db:
    image: postgres:15-alpine
    restart: always
    environment:
      POSTGRES_USER: synapse
      POSTGRES_PASSWORD: "{{ db_password }}"
      POSTGRES_DB: synapse
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --lc-collate=C --lc-ctype=C"
    volumes:
      - ./postgresdata:/var/lib/postgresql/data
      - ./db-init:/docker-entrypoint-initdb.d:ro

  synapse:
    image: matrixdotorg/synapse:latest
    restart: always
    depends_on:
      - db
    ports:
      - "127.0.0.1:8008:8008"
    volumes:
      - ./synapse-data:/data
    environment:
      - SYNAPSE_CONFIG_PATH=/data/homeserver.yaml

  mas:
    image: ghcr.io/element-hq/matrix-authentication-service:latest
    restart: always
    depends_on:
      - db
    command: server
    volumes:
      - ./mas/config.yaml:/config.yaml:ro
    environment:
      - MAS_CONFIG=/config.yaml

  # Coturn needs network_mode: host because it must bind thousands of UDP relay
  # ports (49152-65535). Mapping that range via Docker iptables rules locks up
  # the kernel — host mode is the only viable option.
  coturn:
    image: coturn/coturn:latest
    restart: always
    network_mode: host
    volumes:
      - ./coturn/turnserver.conf:/etc/coturn/turnserver.conf:ro

  # LiveKit also needs network_mode: host for the same reason: WebRTC UDP media
  # ports (50000-50200) and TCP 7881 need direct host binding. The HTTP API
  # (port 7880) is reached by nginx and lk-jwt-service via host-gateway.
  livekit:
    image: livekit/livekit-server:latest
    command: --config /etc/livekit.yaml
    restart: always
    network_mode: host
    volumes:
      - ./livekit/livekit.yaml:/etc/livekit.yaml

  lk-jwt-service:
    image: ghcr.io/element-hq/lk-jwt-service:latest
    restart: always
    environment:
      - LIVEKIT_JWT_BIND=:8081
      # Public URL — returned to clients and used for internal RPC (routed via nginx)
      - LIVEKIT_URL=https://{{ livekit_domain }}
      - LIVEKIT_KEY={{ livekit_key_id }}
      - LIVEKIT_SECRET={{ livekit_secret }}
      - LIVEKIT_FULL_ACCESS_HOMESERVERS={{ matrix_domain }}

  synapse-admin:
    image: awesometechnologies/synapse-admin:latest
    restart: always

  nginx:
    image: nginx:alpine
    restart: always
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/letsencrypt:/etc/letsencrypt:ro
      - ./nginx/certbot-webroot:/var/www/certbot:ro

  certbot:
    image: certbot/certbot:latest
    volumes:
      - ./nginx/letsencrypt:/etc/letsencrypt
      - ./nginx/certbot-webroot:/var/www/certbot
    entrypoint: /bin/sh -c "trap exit TERM; while :; do certbot renew --quiet --webroot -w /var/www/certbot; sleep 12h & wait $${!}; done"

networks:
  default:
    driver: bridge
    ipam:
      config:
        - subnet: 172.22.0.0/16
          gateway: 172.22.0.1
